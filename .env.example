# Copy to .env.local (gitignored) and fill in real values.
# Required for the voicemail notify feature (lib/ntfy.ts) — omit these and
# it just logs a warning and skips sending, nothing else breaks.

# Base URL of your ntfy server.
NTFY_URL=https://ntfy.example.com

# ntfy topic to publish voicemail notifications to. Treat this like a
# secret if your ntfy server doesn't enforce per-topic auth — anyone who
# knows it can publish to (and possibly read) it.
NTFY_TOPIC=your-topic-name

# This pi-web instance's own public HTTPS URL (e.g. a Tailscale MagicDNS
# hostname) — used to build the link the notification's iOS Shortcut
# fetches audio from. Also used by next.config.ts's allowedDevOrigins in
# dev mode.
PI_WEB_PUBLIC_URL=https://your-hostname.example.ts.net
